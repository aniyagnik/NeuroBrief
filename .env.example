# Copy to .env and fill in values.
ASSEMBLYAI_API_KEY=
# Optional: comma-separated model list (default: universal-3-pro,universal-2)
# ASSEMBLYAI_SPEECH_MODELS=universal-3-pro,universal-2
TOGETHER_API_KEY=
HF_API_KEY=
# LLM: auto (Together then Hugging Face), together, or huggingface
# LLM_PROVIDER=auto
# HF_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
# Optional overrides:
# TOGETHER_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1
# MAX_UPLOAD_BYTES=104857600
# UPLOAD_FOLDER=uploads
# SUMMARY_FOLDER=summaries
# DATABASE_URL=sqlite:///feedback.db
# Server
# PORT=5000
# FLASK_DEBUG=0
# LOG_LEVEL=INFO
# Parallel background workers (default: 2)
# JOB_WORKERS=2
# Keep off while using background jobs (reloader kills worker threads)
# FLASK_USE_RELOADER=0
# YouTube bot check — browser where you are logged into YouTube: chrome, firefox, brave
# YTDLP_COOKIES_BROWSER=chrome
