# Copy to .env locally. On Render, set secrets in the dashboard.
ASSEMBLYAI_API_KEY=
HF_API_KEY=
# HF_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
# ASSEMBLYAI_SPEECH_MODELS=universal-3-pro,universal-2
# MAX_UPLOAD_BYTES=104857600
# JOB_WORKERS=1
# FLASK_DEBUG=0
# Local dev — browser logged into YouTube:
# YTDLP_COOKIES_BROWSER=chrome
# Render — pick ONE (Secret File is best; see README):
# YTDLP_COOKIES_GZ_B64=        # small gzip+base64 (from scripts/trim_youtube_cookies.py)
# YTDLP_COOKIES_BASE64=        # large; often exceeds Render limit
# YTDLP_COOKIES_FILE=/etc/secrets/youtube_cookies
